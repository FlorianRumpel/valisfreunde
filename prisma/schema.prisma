datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model Entry {
  id  Int     @id @default(autoincrement())
  pq0 String
  pq1 String?
  pq2 String?
  pq3 String?
  pq4 String?
  // pq5 String

  vq0 String?
  vq1 String?
  vq2 String?
  vq3 String?
  vq4 String?
  // vq5 String

  requestAccepted Boolean  @default(false)
  createdAt       DateTime @default(now())
}
