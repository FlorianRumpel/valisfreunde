datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model Entry {
  id   Int     @id @default(autoincrement())
  name String
  pq0  String?
  pq1  String?
  pq2  String?
  pq3  String?

  vq0 String?
  vq1 String?
  vq2 String?
  vq3 String?
  vq4 String?

  sliders       Json?
  strikeThrough Boolean[] @default([])

  uploadURL String?

  published Boolean  @default(false)
  createdAt DateTime @default(now())

  likes String[] @default([])
}
